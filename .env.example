GROQ_API_KEY=
SIGNOZ_API_KEY=
SIGNOZ_ENDPOINT=

# Per-agent static bearer tokens (policies/agents.yaml). Generate with e.g.
# `python -c "import secrets; print(secrets.token_urlsafe(32))"`.
ATC_TOKEN_CODER_01=
ATC_TOKEN_ASSIST_01=
ATC_TOKEN_COMPLY_01=

# Per-agent cumulative token budget. When an agent's heartbeat-reported
# spend crosses this, the gateway denies further tool calls with
# [ATC-BUDGET]. Unset or 0 disables the breaker.
ATC_TOKEN_BUDGET=
